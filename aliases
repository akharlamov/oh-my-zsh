alias ls='ls -G'
alias grep='grep --color'
alias fu='sudo $( fc -ln -1)'
alias g='git'
alias ll='ls -Glrah'

# command L equivalent to command |less
alias -g L='|less' 

# command S equivalent to command &> /dev/null &
alias -g S='&> /dev/null &'

alias -g G='|grep -a'

# Docker helpers
alias -g dcps='docker ps -a '
alias -g dcrm='docker rm '
alias -g dcrun='docker run '

# Terraform
alias -g tf='terraform '
alias -g gssh='gcloud compute ssh '

